# Copy this file to .env and fill in your values
# cp env.template .env

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
# Update with your PostgreSQL connection string
# Format: postgresql://username:password@localhost:5432/swipeshare
DATABASE_URL=postgresql://postgres:password@localhost:5432/swipeshare

# JWT Authentication
# Generate a secure random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Stripe Payment Integration
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (for verification codes)
# Gmail example - you'll need an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
EMAIL_FROM=noreply@swipeshare.app

# MIT Email Domain (for verification)
MIT_EMAIL_DOMAIN=mit.edu

# Redis (optional, for caching/rate limiting)
# Install Redis locally or use a cloud service
REDIS_URL=redis://localhost:6379

# Frontend URL (for Stripe Connect redirects)
FRONTEND_URL=http://localhost:3000

